# Google OAuth Configuration
# Get your Client ID from: https://console.cloud.google.com/
# Instructions: See CLAUDE.md for setup details
VITE_GOOGLE_CLIENT_ID=your-client-id-here

# GitHub Repository URL (optional)
# Used by FeedbackButton to direct users to report issues
# If not set, the FeedbackButton will not be displayed
VITE_GITHUB_REPO_URL=https://github.com/your-org/your-repo
